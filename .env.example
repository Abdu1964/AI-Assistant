# LLM Configuration
# For lighter tasks 
BASIC_LLM_PROVIDER=openai
BASIC_LLM_VERSION=gpt-3.5-turbo

# For complex tasks
ADVANCED_LLM_PROVIDER=openai
ADVANCED_LLM_VERSION=gpt-4o

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here




# Hypothesis API Endpoints (Mock Services)
HYPOTHESIS_CHAT_ENDPOINT=http://localhost:9001/api/mock/hypothesis/chat # Endpoint used to retrieve existing hypotheses and their details by ID.
HYPOTHESIS_MAIN_ENDPOINT=http://localhost:9001/api/mock/hypothesis/main # Endpoint for checking generation status (polling) and triggering the final hypothesis creation.
HYPOTHESIS_DATA_API=http://localhost:9001/api/mock/hypothesis      # Endpoint for starting the data enrichment process and fetching intermediate results.




NEO4J_URI=<neo4j uri>
NEO4J_USERNAME=<neo4j username>
NEO4J_PASSWORD=<neo4j password>

# Authentication
JWT_SECRET=your_jwt_secret_here


# Flask Configuration
FLASK_PORT=5002

# Qdrant Configuration
QDRANT_CLIENT=http://localhost:6333

# Embedding Configuration
EMBEDDING_MODEL=gemini
VECTOR_COLLECTION=SITE_INFORMATION_gemini

# MongoDB Configuration
MONGO_USERNAME=admin
MONGO_PASSWORD=your_mongodb_password_here
MONGO_DATABASE=ai_assistant
MONGO_URL=mongodb://admin:your_mongodb_password_here@mongodb:27017/

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# Optional: Platform Backend Endpoints
NEO4J_URI=your_neo4j_uri_here
NEO4J_USERNAME=your_neo4j_username_here
NEO4J_PASSWORD=your_neo4j_password_here

ANNOTATION_SERVICE_URL=http://l

# Galaxy MCP Server Configuration
GALAXY_MCP_SERVER=http://

# bioGPT Configuration
BIOGPT_THREADS=1
